{
  auto_https off
  admin localhost:2019
}

:8080 {
  encode gzip zstd

  @health path /health
  @api path /entities* /events* /ingest/event /project/repo

  handle @health {
    reverse_proxy 127.0.0.1:8787
  }

  handle @api {
    reverse_proxy 127.0.0.1:8787
  }

  handle {
    respond "Syncrescendence ontology API surface" 200
  }
}
